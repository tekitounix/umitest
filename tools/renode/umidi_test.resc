# Renode script for umidi library testing
# Usage: renode --console --disable-xwt renode/umidi_test.resc

using sysbus

mach create "umidi_test"

# Load custom UMI-OS platform description
machine LoadPlatformDescription $CWD/renode/stm32f4_test.repl

# Load the test ELF
sysbus LoadELF $CWD/.build/umidi_test_renode.elf

# Set VTOR to point to flash where vector table is located
sysbus WriteDoubleWord 0xE000ED08 0x08000000

# Read entry point from vector table and set CPU registers
# Vector table: [0] = SP, [1] = Reset handler
# SP from vector table: 0x2000a010
# Reset handler from vector table: 0x080001cd (with Thumb bit)
cpu SP 0x2000a010
cpu PC 0x080001cc

# Log UART to file for verification (not append, fresh log)
logFile $CWD/.build/umidi_uart.log
usart2 CreateFileBackend $CWD/.build/umidi_uart.log false

echo "=== umidi Test Suite Starting ==="

# Run emulation for 10 seconds (virtual time) - extended for benchmarks
emulation RunFor "10"

echo "=== Test finished ==="
quit
