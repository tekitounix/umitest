# Renode script for UMI-OS automated testing
# Usage: renode --console --disable-xwt renode/test.resc

using sysbus

mach create "umi_test"

# Load custom UMI-OS platform description
machine LoadPlatformDescription $CWD/renode/stm32f4_test.repl

# Load the test ELF
sysbus LoadELF $CWD/.build/renode_test.elf

# Set VTOR to point to flash (0x08000000) where vector table is located
sysbus WriteDoubleWord 0xE000ED08 0x08000000

# Set PC to entry point and SP to top of RAM
cpu PC 0x80004c9
cpu SP 0x20020000

# Log UART to file for verification
logFile $CWD/.build/renode_uart.log
usart2 CreateFileBackend $CWD/.build/renode_uart.log true

echo "=== UMI-OS Test Suite Starting ==="

# Run emulation for 5 seconds (virtual time) - extended for benchmark
emulation RunFor "5"

echo "=== Test finished ==="
quit
