    <briefdescription>
<para>Converts MIDI 1.0 byte stream to <ref refid="structumidi_1_1_u_m_p32" kindref="compound">UMP32</ref>. </para>
    </briefdescription>
    <detaileddescription>
<para>Optimizations:<itemizedlist>
<listitem><para>Incremental UMP word construction during parse</para>
</listitem><listitem><para>Single status byte classification</para>
</listitem><listitem><para>Minimal branching with early detection of 2-byte messages</para>
</listitem></itemizedlist>
</para>
<para><simplesect kind="par"><title>Example:</title><para><programlisting><codeline><highlight class="normal">Parser<sp/>parser;</highlight></codeline>
<codeline><highlight class="normal">UMP32<sp/>ump;</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keywordflow">for</highlight><highlight class="normal"><sp/>(uint8_t<sp/></highlight><highlight class="keywordtype">byte</highlight><highlight class="normal"><sp/>:<sp/>midi_bytes)<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keywordflow">if</highlight><highlight class="normal"><sp/>(parser.parse(</highlight><highlight class="keywordtype">byte</highlight><highlight class="normal">,<sp/>ump))<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>process_ump(ump);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>}</highlight></codeline>
<codeline><highlight class="normal">}</highlight></codeline>
</programlisting> </para>
</simplesect>
</para>
    </detaileddescription>
